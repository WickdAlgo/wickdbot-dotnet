{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "curl -sSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh && bash /tmp/dotnet-install.sh --channel 8.0 --install-dir $HOME/.dotnet && $HOME/.dotnet/dotnet tool restore",
  "buildCommand": "$HOME/.dotnet/dotnet docfx docs/docfx.json",
  "outputDirectory": "docs/_site"
}
