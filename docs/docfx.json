{
  "$schema": "https://dotnet.github.io/docfx/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/Wickd.Core/Wickd.Core.csproj",
            "src/Wickd.Adapters.Ccxt/Wickd.Adapters.Ccxt.csproj"
          ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "disableDefaultFilter": false,
      "includePrivateMembers": false,
      "memberLayout": "samePage",
      "namespaceLayout": "nested",
      "properties": {
        "Configuration": "Release",
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "business-flows.md",
          "toc.yml"
        ]
      },
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "WickdAlgo",
      "_appTitle": "WickdAlgo Docs",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
